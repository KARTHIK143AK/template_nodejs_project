{
  "name": "cricbuzz-system-design",
  "version": "0.1.0",
  "description": "Personal learning repo for Cricbuzz system design",
  "main": "dist/server/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node ./server/main.ts",
    "start": "npm run build && node ./dist/server/main.js",
    "start:dev": "cross-env NODE_ENV=dev nodemon --watch server --watch internal --watch documentation --ext ts,js,json --exec \"ts-node server/main.ts\""
  },
  "engines": {
    "node": "^22.0.0"
  },
  "dependencies": {
    "dotenv": "17.4.0",
    "koa": "2.14.1",
    "koa-router": "14.0.0",
    "mongodb": "^7.1.1",
    "node-vault": "0.12.0"
  },
  "devDependencies": {
    "@types/koa": "2.13.4",
    "@types/koa-router": "7.4.4",
    "@types/node": "20.11.0",
    "cross-env": "7.0.3",
    "nodemon": "3.0.1",
    "ts-node": "10.9.1",
    "typescript": "5.6.2"
  }
}
